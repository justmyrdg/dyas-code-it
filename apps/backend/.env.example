# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dyascodeit
# Migrations run on boot by default. Set DB_SYNC=true to sync models directly
# instead (local throwaway databases only — never in production).
DB_SYNC=false

# Auth
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Existing account promoted to admin on server start (registration cannot create admins)
ADMIN_EMAIL=

# OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Claude for Dyas
CLAUDE_API_KEY=your_claude_api_key
DYAS_MODEL=claude-sonnet-5

# Code execution (Piston). Defaults to the public instance; override to self-host.
PISTON_URL=https://emkc.org/api/v2/piston

# Frontend URL
FRONTEND_URL=http://localhost:4200

# Authenticated app (separate from the landing site above)
APP_URL=http://localhost:4201

# Email (SMTP — used for password reset emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
